# ================================
# PostgreSQL
# ================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=rent_reg

# ================================
# Backend
# ================================
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/rent_reg
JWT_SECRET=change-me-in-production
USE_DATABASE=false

# ================================
# Directus CRM
# ================================
DIRECTUS_URL=http://localhost:8055
DIRECTUS_SECRET=change-me-in-production
DIRECTUS_ADMIN_EMAIL=admin@example.com
DIRECTUS_ADMIN_PASSWORD=admin123

# ================================
# S3 / MinIO
# ================================
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=files-media
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# ================================
# OCR
# ================================
OCR_SPACE_API_KEY=
YANDEX_VISION_API_KEY=
YANDEX_FOLDER_ID=
MIN_CONFIDENCE=0.85
OCR_FALLBACK_ENABLED=true
PADDLE_LANG=multilingual
OCR_SLA_TOTAL_TIMEOUT_SECONDS=8

# ================================
# Auth (dev only)
# ================================
TEST_SMS_CODE=1234

# ================================
# Telegram (adapter, WAVE 9)
# ================================
BOT_TOKEN=

